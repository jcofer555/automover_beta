For older releases, see https://github.com/jcofer555/automover_beta/releases
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/automover_beta/jdupes-1.30.0-x86_64-2_slackdce.txz">
<URL>https://github.com/jcofer555/automover_beta/raw/refs/heads/main/packages/jdupes-1.30.0-x86_64-2_slackdce.txz</URL>
</FILE>

<FILE Name="/boot/config/plugins/automover_beta/libjodycode-4.0.1-x86_64-2_slackdce.txz">
<URL>https://github.com/jcofer555/automover_beta/raw/refs/heads/main/packages/libjodycode-4.0.1-x86_64-2_slackdce.txz</URL>
</FILE>

<FILE Name="/boot/config/plugins/automover_beta/unraid-automover_beta-2026.03.16.01-noarch-1.txz">
<URL>https://github.com/jcofer555/automover_beta/releases/download/2026.03.16.01/unraid-automover_beta-2026.03.16.01-noarch-1.txz</URL>
<SHA256>42b536d0f17b192f9a22bdb3d56e0323ac29d9744432c45dcdd53dea55692865</SHA256>
</FILE>

<!-- ==========================================================
     INSTALL SCRIPT
========================================================== -->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
# ==========================================================
#  INSTALL / UPGRADE LOGIC
# ==========================================================

PACKAGE_TXZ="/boot/config/plugins/automover_beta/unraid-automover_beta-2026.03.16.01-noarch-1.txz"
USER_CFG="/boot/config/plugins/automover_beta/settings.cfg"
DEFAULT_CFG="/usr/local/emhttp/plugins/automover_beta/helpers/default_settings.cfg"
TMP_CFG="/tmp/automover_beta_settings.tmp"
CRON_FILE="/boot/config/plugins/automover_beta/automover_beta.cron"

# Install the package
upgradepkg --install-new "$PACKAGE_TXZ"
upgradepkg --install-new "/boot/config/plugins/automover_beta/jdupes-1.30.0-x86_64-2_slackdce.txz"
upgradepkg --install-new "/boot/config/plugins/automover_beta/libjodycode-4.0.1-x86_64-2_slackdce.txz"

# Ensure tmp directory exists
mkdir -p /tmp/automover_beta

# Ordered config keys (new cron-only model)
ordered_keys=(
    "AGE_BASED_FILTER"
    "AGE_DAYS"
    "ALLOW_DURING_PARITY"
    "AUTOSTART"
    "CONTAINER_NAMES"
    "CRON_EXPRESSION"
    "CRON_MODE"
    "DAILY_TIME"
    "DRY_RUN"
    "ENABLE_CLEANUP"
    "ENABLE_JDUPES"
    "ENABLE_NOTIFICATIONS"
    "ENABLE_SCRIPTS"
    "ENABLE_TRIM"
    "EXCLUSIONS_ENABLED"
    "FORCE_RECONSTRUCTIVE_WRITE"
    "HASH_PATH"
    "HIDDEN_FILTER"
    "HOURLY_FREQUENCY"
    "IO_PRIORITY"
    "MANUAL_MOVE"
    "MONTHLY_DAY"
    "MONTHLY_TIME"
    "NOTIFICATION_SERVICE"
    "POOL_NAME"
    "POST_SCRIPT"
    "PRE_SCRIPT"
    "PRIORITIES"
    "PROCESS_PRIORITY"
    "PUSHOVER_USER_KEY"
    "QBITTORRENT_DAYS_FROM"
    "QBITTORRENT_DAYS_TO"
    "QBITTORRENT_HOST"
    "QBITTORRENT_PASSWORD"
    "QBITTORRENT_SCRIPT"
    "QBITTORRENT_STATUS"
    "QBITTORRENT_USERNAME"
    "SIZE_BASED_FILTER"
    "SIZE_MB"
    "SIZE_UNIT"
    "STOP_ALL_CONTAINERS"
    "STOP_THRESHOLD"
    "THRESHOLD"
    "WEBHOOK_DISCORD"
    "WEBHOOK_GOTIFY"
    "WEBHOOK_NTFY"
    "WEBHOOK_PUSHOVER"
    "WEBHOOK_SLACK"
    "WEEKLY_DAY"
    "WEEKLY_TIME"
)

# ==========================================================
#  CONFIG MANAGEMENT
# ==========================================================
if [ ! -f "$USER_CFG" ]; then
    cp "$DEFAULT_CFG" "$USER_CFG"
else
    # Add missing keys from default
    while IFS='=' read -r key val; do
        [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
        if ! grep -q -E "^[[:space:]]*${key}[[:space:]]*=" "$USER_CFG"; then
            echo "$key=$val" >> "$USER_CFG"
        fi
    done < "$DEFAULT_CFG"
fi

# Rebuild ordered version (only known keys, drop extra lines)
{
    for key in "${ordered_keys[@]}"; do
        grep -E "^[[:space:]]*${key}[[:space:]]*=" "$USER_CFG"
    done
} > "$TMP_CFG"

mv "$TMP_CFG" "$USER_CFG"

# ==========================================================
#  LOAD SETTINGS & SETUP CRON
# ==========================================================
SETTINGS="/boot/config/plugins/automover_beta/settings.cfg"
if [ -f "$SETTINGS" ]; then
    source "$SETTINGS"
fi

# === Check for Mover Tuning plugin ===
MOVER_TUNING="/boot/config/plugins/ca.mover.tuning.plg"
MOVER_TUNING_DIR="/usr/local/emhttp/plugins/ca.mover.tuning"

if realpath "$MOVER_TUNING" &>/dev/null || [ -d "$MOVER_TUNING_DIR" ]; then
  if [ -f "$MOVER_TUNING" ] || [ -d "$MOVER_TUNING_DIR" ]; then
    echo -e "⚠️ Mover Tuning plugin appears to be installed. Having both can result in conflicts between Mover Tuning and automover_beta.\nConsider uninstalling one to avoid incompatibility issues"
  fi
fi

# Remove older txz packages (keep only the current one)
find /boot/config/plugins/automover_beta/ -maxdepth 1 -type f -name "unraid-automover_beta-*.txz" ! -name "unraid-automover_beta-2026.03.16.01-noarch-1.txz" -delete

# Ensure helper scripts are executable
chmod +x /usr/local/emhttp/plugins/automover_beta/helpers/*

# ==========================================================
#  HANDLE AUTOSTART + CRON GENERATION (NEW CRON-ONLY MODEL)
# ==========================================================
CRON_CMD="/usr/local/emhttp/plugins/automover_beta/helpers/automover_beta.sh &> /dev/null 2>&1"

if [ "$AUTOSTART" == "no" ]; then
    rm -f "$CRON_FILE"
else
    if [ -n "$CRON_EXPRESSION" ]; then
        echo "${CRON_EXPRESSION} ${CRON_CMD}" > "$CRON_FILE"
    else
        rm -f "$CRON_FILE"
    fi
    update_cron
fi

echo ""
echo "----------------------------------------------------"
echo " automover_beta has been installed."
echo " Version: 2026.03.16.01"
echo "----------------------------------------------------"
echo ""
echo "⚠️ If you were on version 2025.12.15.04 or earlier, reconfigure your schedule in Settings → automover_beta"
echo ""
echo ""
echo "⚠️ It's suggested to disable unraids built in mover schedule at settings > scheduler this requires unraid 7.2.1+"
echo ""

]]>
</INLINE>
</FILE>

<!-- ==========================================================
     REMOVE SCRIPT
========================================================== -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
removepkg unraid-automover_beta
removepkg "/boot/config/plugins/automover_beta/jdupes-1.30.0-x86_64-2_slackdce.txz"
removepkg "/boot/config/plugins/automover_beta/libjodycode-4.0.1-x86_64-2_slackdce.txz"
rm -f /boot/config/plugins/automover_beta/jdupes-1.30.0-x86_64-2_slackdce.txz
rm -f /boot/config/plugins/automover_beta/libjodycode-4.0.1-x86_64-2_slackdce.txz
rm -rf /usr/local/emhttp/plugins/automover_beta
rm -rf /boot/config/plugins/automover_beta
]]>
</INLINE>
</FILE>

</PLUGIN>
