<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN 
  name="automover_beta"
  author="jcofer555"
  version="2026.03.16.01"
  launch="Settings/automover_beta"
  pluginURL="https://raw.githubusercontent.com/jcofer555/automover_beta/main/plugin/automover_beta.plg"
  support="https://forums.unraid.net/topic/192216-automover_beta-for-unraid/"
  min="7.1.99"
  
  icon="icon.png"
>

