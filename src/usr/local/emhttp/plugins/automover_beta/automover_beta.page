    'WEBHOOK_PUSHOVER'       => '',
    'WEBHOOK_SLACK'          => '',
];
$existing = file_exists(CFG_PATH) ? (parse_ini_file(CFG_PATH) ?: []) : [];
// Remove stale cron keys if present
foreach (STALE_KEYS as $sk) { unset($existing[$sk]); }
foreach ($defaults as $k=>$v) { if (!array_key_exists($k,$existing)) $existing[$k]=$v; }
// Write alphabetically so key order never shifts
$write = []; foreach ($defaults as $k=>$dv) { $write[$k] = $existing[$k]; }
ksort($write);
$cfg=''; foreach ($write as $k=>$v) { $cfg.="$k=\"{$v}\"\n"; }
@file_put_contents(CFG_PATH,$cfg);
$settings=$existing;
$unraid_version='7.1';
if (file_exists('/etc/unraid-version')) { $d=parse_ini_file('/etc/unraid-version'); if (!empty($d['version'])) $unraid_version=$d['version']; }
$sib_checks=[
    'automover'             =>['plg'=>'/boot/config/plugins/automover.plg','page'=>'/usr/local/emhttp/plugins/automover/automover.page','label'=>'Automover','url'=>'/Settings/automover'],
    'flash-backup'          =>['plg'=>'/boot/config/plugins/flash-backup.plg','page'=>'/usr/local/emhttp/plugins/flash-backup/flash-backup.page','label'=>'Flash Backup','url'=>'/Settings/flash-backup'],
    'flash-backup_beta'     =>['plg'=>'/boot/config/plugins/flash-backup_beta.plg','page'=>'/usr/local/emhttp/plugins/flash-backup_beta/flash-backup_beta.page','label'=>'Flash Backup (Beta)','url'=>'/Settings/flash-backup_beta'],
