const CFG_PATH = '/boot/config/plugins/automover_beta/settings.cfg';
if (session_status() === PHP_SESSION_NONE) session_start();

// Keys that are no longer stored in settings.cfg (moved to schedules.cfg)
const STALE_KEYS = ['CRON_EXPRESSION','CRON_MODE','DAILY_TIME','DAILY_MINUTE',
    'HOURLY_FREQUENCY','MONTHLY_DAY','MONTHLY_MINUTE','MONTHLY_TIME','PROCESS_PRIORITY',
