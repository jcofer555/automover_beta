    'vm-backup-and-restore_beta'=>['plg'=>'/boot/config/plugins/vm-backup-and-restore_beta.plg','page'=>'/usr/local/emhttp/plugins/vm-backup-and-restore_beta/vm-backup-and-restore_beta.page','label'=>'VM Backup & Restore (Beta)','url'=>'/Settings/vm-backup-and-restore_beta'],
];
$sibs=[]; $cur=basename(dirname(__FILE__));
foreach ($sib_checks as $k=>$c) { if ($k===$cur) continue; if (file_exists($c['plg'])&&file_exists($c['page'])) $sibs[$k]=$c; }
$has_sibs=!empty($sibs); $sib_opts=$sibs; uasort($sib_opts,fn($a,$b)=>strcmp($a['label'],$b['label']));
$notif_svcs=['Discord','Gotify','Ntfy','Pushover','Slack','Unraid'];
$sel_svcs=array_filter(array_map('trim',explode(',',$settings['NOTIFICATION_SERVICE']??'')));
$sharesFile='/var/local/emhttp/shares.ini'; $curHash=$settings['HASH_LOCATION']??'/mnt/user/appdata'; $sharesList=[];
if (file_exists($sharesFile)){$sh=parse_ini_file($sharesFile,true);if($sh)$sharesList=array_keys($sh);}
